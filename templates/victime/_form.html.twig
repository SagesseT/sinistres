{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
<div class="row g-3">

    <div class="col-md-4">
        {{ form_label(form.nom, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Entrez le nom'}}) }}
        {{ form_errors(form.nom) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.postnom, 'Postnom', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.postnom, {'attr': {'class': 'form-control', 'placeholder': 'Entrez le postnom'}}) }}
        {{ form_errors(form.postnom) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.prenom, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Entrez le prénom'}}) }}
        {{ form_errors(form.prenom) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.sexe, 'Sexe', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.sexe, {'attr': {'class': 'form-select'}}) }}
        {{ form_errors(form.sexe) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.adresse, 'Adresse', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Entrez l\'adresse'}}) }}
        {{ form_errors(form.adresse) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.telephone, 'Téléphone', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': 'Entrez le numéro'}}) }}
        {{ form_errors(form.telephone) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.photo, 'Photo', {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.photo, {'attr': {'class': 'form-control', 'type': 'file'}}) }}
        {{ form_errors(form.photo) }}
    </div>

</div>

<div class="mt-4">
    <button class="btn btn-primary">{{ button_label|default('Enregistrer') }}</button>
    <a href="{{ path('app_victime_index') }}" class="btn btn-secondary ms-2">Annuler</a>
</div>

{{ form_end(form) }}
