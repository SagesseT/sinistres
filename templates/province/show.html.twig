{% extends 'base.html.twig' %}

{% block title %}Province{% endblock %}

{% block body %}
<main id="main" class="main">
    <h1>Province</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ province.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ province.nom }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_province_index') }}">back to list</a>

    <a href="{{ path('app_province_edit', {'id': province.id}) }}">edit</a>

    {{ include('province/_delete_form.html.twig') }}
     </main>
{% endblock %}
