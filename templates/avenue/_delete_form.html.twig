<form method="post" action="{{ path('app_avenue_delete', {'id': avenue.id}) }}"
      onsubmit="return confirm('Supprimer cette avenue ?');"
      style="display:inline-block">

    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ avenue.id) }}">

    <button class="btn btn-danger btn-sm">
        🗑
    </button>
</form>