{% extends 'base.html.twig' %}

{% block title %}Gestion des Avenues{% endblock %}

{% block body %}
<main class="main">
<div class="container mt-4">

    {# 🔷 HEADER #}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📍 Gestion des Avenues</h3>

        <div class="d-flex gap-2">
            <a href="{{ path('app_avenue_import') }}" class="btn btn-primary">
                <i class="bi bi-upload"></i> Importer
            </a>

            <a href="{{ path('app_avenue_new') }}" class="btn btn-success">
                <i class="bi bi-plus"></i> Ajouter
            </a>
        </div>
    </div>

    {# 🔔 MESSAGE #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# 🔍 RECHERCHE #}
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="🔍 Rechercher une avenue...">
        </div>
    </div>

    {# 📊 TABLEAU #}
    <div class="card shadow-sm">
        <div class="card-body table-responsive">

            <table class="table table-hover align-middle" id="avenueTable">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nom de l'avenue</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                {% for avenue in avenues %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td class="fw-bold">{{ avenue.nom }}</td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a href="{{ path('app_avenue_show', {'id': avenue.id}) }}" class="btn btn-info btn-sm">
                                    👁
                                </a>
                                <a href="{{ path('app_avenue_edit', {'id': avenue.id}) }}" class="btn btn-warning btn-sm">
                                    ✏️
                                </a>
                                {{ include('avenue/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center">Aucune avenue trouvée</td>
                    </tr>
                {% endfor %}
                </tbody>

            </table>

        </div>
    </div>

</div>
</main>

{# 🔥 SCRIPT RECHERCHE LIVE #}
<script>
document.getElementById('searchInput').addEventListener('keyup', function () {
    let value = this.value.toLowerCase();
    let rows = document.querySelectorAll("#avenueTable tbody tr");

    rows.forEach(function (row) {
        let text = row.innerText.toLowerCase();
        row.style.display = text.includes(value) ? "" : "none";
    });
});
</script>

{% endblock %}
