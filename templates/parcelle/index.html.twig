{% extends 'base.html.twig' %}

{% block title %}Gestion des Parcelles
{% endblock %}

{% block body %}
	<main id="main" class="main">
		<div
			class="container-fluid mt-4">
			{# En-tête de page #}
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h1 class="h3 mb-0 text-gray-800">📦 Gestion des Parcelles</h1>
				<a href="{{ path('app_parcelle_new') }}" class="btn btn-primary shadow-sm">
					<i class="bi bi-plus-lg"></i>
					Nouvelle Parcelle
				</a>
			</div>

			{# Carte principale #}
			<div class="card shadow mb-4">
				<div class="card-header py-3 bg-light">
					<div class="row align-items-center">
						<div class="col">
							<h6 class="m-0 font-weight-bold text-primary">Liste des enregistrements</h6>
						</div>
						<input type="text" id="searchInput" class="form-control bg-white border-primary" placeholder="🔎 Rechercher victime, avenue ou numéro...">
					</div>
				</div>

				<div class="card-body p-0">
					<div class="table-responsive">
						<table class="table table-hover mb-0 align-middle">
							<thead class="table-light">
								<tr>
									<th class="ps-4">#</th>
									<th>Victime (Propriétaire)</th>
									<th>Localisation (Avenue)</th>
									<th>N° Parcelle</th>
									<th class="text-center">Occupants (H/F/E)</th>
									<th>Documents</th>
									<th>Date Enreg.</th>
									<th class="text-end pe-4">Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for parcelle in parcelles %}
									<tr>
										<td class="ps-4 text-muted">{{ loop.index }}</td>
										<td>
											<div class="d-flex align-items-center">
												<div class="avatar-circle me-2">
													{{ parcelle.victime.nom|first|upper }}
												</div>
												<div>
													<div class="fw-bold text-dark">{{ parcelle.victime.nom|upper }}
														{{ parcelle.victime.prenom }}</div>
													<small class="text-muted">{{ parcelle.victime.numerodossier }}</small>
												</div>
											</div>
										</td>
										<td>
											<i class="bi bi-geo-alt text-danger"></i>
											{{ parcelle.avenue ? parcelle.avenue.nom : 'Non précisée' }}
										</td>
										<td>
											<span class="badge rounded-pill bg-info text-dark">
												№
												{{ parcelle.numero }}
											</span>
										</td>
										<td class="text-center">
											<span class="badge bg-light text-dark border">
												<small>M:
													{{ parcelle.homme }}
													| F:
													{{ parcelle.femme }}
													| E:
													{{ parcelle.enfant }}</small>
											</span>
										</td>
										<td>
											{% if parcelle.documents|length > 0 %}

												<ul class="list-unstyled mb-0">

													{% for doc in parcelle.documents %}

														{% if doc.fichier %}

															<li>
																<a href="{{ asset('uploads/documents/' ~ doc.fichier) }}" target="_blank">
																	📎
																	{{ doc.typedocument ? doc.typedocument.nom : 'Document' }}
																</a>
															</li>

														{% else %}

															<li class="text-danger">
																⚠️
																{{ doc.typedocument ? doc.typedocument.nom : 'Document' }}
																sans fichier
															</li>

														{% endif %}

													{% endfor %}

												</ul>

											{% else %}
												<span class="text-muted">Aucun document</span>
											{% endif %}
										</td>
										<td>
											<small class="text-muted">
												<i class="bi bi-calendar3"></i>
												{{ parcelle.datecreated|date('d/m/Y') }}
											</small>
										</td>
										<td class="text-end pe-4">
											<div class="btn-group">
												<a href="{{ path('app_parcelle_show', {'id': parcelle.id}) }}" class="btn btn-outline-primary btn-sm" title="Détails">
													<i class="bi bi-eye"></i>
												</a>
												<a href="{{ path('app_parcelle_edit', {'id': parcelle.id}) }}" class="btn btn-outline-warning btn-sm" title="Modifier">
													<i class="bi bi-pencil"></i>
												</a>
											</div>
										</td>
									</tr>
								{% else %}
									<tr>
										<td colspan="8" class="text-center py-5">
											<i class="bi bi-folder-x display-4 text-muted"></i>
											<p class="mt-2">Aucun résultat trouvé pour votre recherche.</p>
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</div>
	</main>

	<script>
document.getElementById('searchInput').addEventListener('keyup', function () {

    let value = this.value.toLowerCase();
    let rows = document.querySelectorAll('table tbody tr');

    rows.forEach(function (row) {

        // texte complet de la ligne
        let text = row.textContent.toLowerCase();

        // filtre simple
        if (text.includes(value)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }

    });

});
</script>
{% endblock %}
